class Solution {
    void dfs(int r,int c,char[][] board,boolean[][] visit){
        visit[r][c]=true;
        board[r][c]='#';
        int m=board.length;
        int n=board[0].length;
        int[] row={-1,0,1,0};
        int[] col={0,1,0,-1};
        for(int l=0;l<4;l++){
            int i=r+row[l];
            int j=c+col[l];
            if(i>=0 && i<m && j>=0 && j<n && board[i][j]=='O' && !visit[i][j]){
                dfs(i,j,board,visit);
            }
        }
    }
    public void solve(char[][] board) {
      int m=board.length;
      int n=board[0].length;
      boolean[][] visit= new boolean[m][n];
      for(int i=0;i<n;i++){
        if(board[0][i]=='O' && !visit[0][i]) dfs(0,i,board,visit);
        if(board[m-1][i]=='O' && !visit[m-1][i]) dfs(m-1,i,board,visit);
      } 
      for(int i=0;i<m;i++){
        if(board[i][0]=='O' && !visit[i][0]) dfs(i,0,board,visit);
        if(board[i][n-1]=='O' && !visit[i][n-1]) dfs(i,n-1,board,visit);
      }
       for(int i=0;i<m;i++){
        for(int j=0;j<n;j++){
            if(board[i][j]=='#') board[i][j]='O';
            else board[i][j]='X';
        }
       }
    }
}
