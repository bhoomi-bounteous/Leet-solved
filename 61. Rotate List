class Solution {
    public ListNode rotateRight(ListNode head, int k) {
        if(head==null || head.next==null || k==0) return head;
        int count=1;
        ListNode curr=head;
        while(curr.next!=null){
            count++;
            curr=curr.next;
        }
        curr.next=head;
        k=k%count;
        count-=k;
        curr=head;
        while(count!=1){
           curr=curr.next;
           count--;
        }
        ListNode nhead=curr.next;
        curr.next=null;
        return nhead;
    }
}
