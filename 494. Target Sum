class Solution {
    int find(int indx,int target,int[] nums,int[][] dp){
        if(indx==nums.length) return target==0?1:0;
        if(indx==nums.length) return 0;
        if(dp[indx][target]!=-1) return dp[indx][target];
        int pick=0;
        if(nums[indx]<=target){
          pick=find(indx+1,target-nums[indx],nums,dp);
        }
        int npick=find(indx+1,target,nums,dp);
        return dp[indx][target]= pick+npick;
    }
    public int findTargetSumWays(int[] nums, int target) {
        int sum=0;
        for(int i: nums) sum+=i;
        if(Math.abs(target)>sum) return 0;
        if((sum-target)%2!=0) return 0;
         int sum2=(sum-target)/2;
           int[][] dp=new int[nums.length][sum2+1];
            for(int i=0;i<nums.length;i++){
            Arrays.fill(dp[i],-1);
         }
         return find(0,sum2,nums,dp);

    }
}
