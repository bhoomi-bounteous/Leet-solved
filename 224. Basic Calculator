class Solution {
    public int calculate(String s) {
        Stack<Integer> stack=new Stack<>();
        int number=0;
        int result=0;
        int sign=1;
        for(int i : s.toCharArray()){
            if(i=='+' || i=='-'){
                result+=(number*sign);
                number=0;
                  if(i=='-') sign=-1;
                  else sign=1;
            }else if(i=='('){
                stack.add(result);
                stack.add(sign);
                result=0;
                number=0;
                sign=1;
            }else if(i==')'){
                result+=(number*sign);
                int prevSign = stack.pop(); 
                 int prevResult = stack.pop();
                 result = prevResult + (prevSign*result);
                 number=0;
            }else if(Character.isDigit(i)){
                number*=10;
                number+=(i-'0');
            }
        }
         result+=(number*sign);
        return result;
    }
}
