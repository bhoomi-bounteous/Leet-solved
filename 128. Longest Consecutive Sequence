class Solution {
    public int longestConsecutive(int[] nums) {
        if(nums.length==0) return 0;
        Set<Integer> set=new HashSet<>();
        for(int i : nums) set.add(i);
        int len=1;
        for(int i : set){
            int curr=1;
            int start=i;
            if(!set.contains(i-1)){
                while(set.contains(start+1)){
                    curr++;
                    start+=1;
                }
                len=Math.max(curr,len);
            }
        }
        return len;
    }
}
