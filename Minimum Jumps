class Solution {
    public int minJumps(int[] arr) {
        if(arr[0]==0) return -1;
        int jump=0;
        int max=0;
        int curr=0;
        for(int i=0;i<arr.length;i++){
            max=Math.max(max,(i+arr[i]));
          if(i==curr){
              curr=max;
              jump++;
              if(curr>=arr.length-1) return jump;
          }
        }
        return -1;
    }
}
