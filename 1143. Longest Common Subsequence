class Solution {
    public int longestCommonSubsequence(String s1, String s2) {
        int n=s1.length();
        int m=s2.length();
        int[][] dp= new int[n+1][m+1];
        for(int i=n-1;i>=0;i--){
            for(int j=m-1;j>=0;j--){
                int sub=0;
                if(s1.charAt(i)==s2.charAt(j)) sub=1+dp[i+1][j+1];
                else{
                    sub=Math.max(dp[i+1][j],dp[i][j+1]);
                }
                dp[i][j]=sub;
            }
        }
        return dp[0][0];
    }
}
