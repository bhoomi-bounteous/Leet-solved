class Solution {
    int money(int i,int n,int[] nums,int[] dp){
        if(i>n) return 0;
        if(dp[i]!=-1) return dp[i];
        int pick=money(i+2,n,nums,dp)+nums[i];
        int npick=money(i+1,n,nums,dp);
        return dp[i]=Math.max(pick,npick);
    }
    public int rob(int[] nums) {
        if(nums.length==1) return nums[0];
        int[] dp= new int[nums.length];
        Arrays.fill(dp,-1);
        int one=money(0,nums.length-2,nums,dp);
        Arrays.fill(dp,-1);
        int two=money(1,nums.length-1,nums,dp);
        return Math.max(one,two);
    }
}
