class Solution {
    public void rotate(int[][] matrix) {
        int col=matrix[0].length;
        for(int i=0;i<matrix.length;i++){
            for(int j=0;j<i;j++){
                int temp=matrix[i][j];
                matrix[i][j]=matrix[j][i];
                matrix[j][i]=temp;
            }
        }
        for(int i=0;i<matrix.length;i++){
            for(int j=0;j<col/2;j++){
                 int temp=matrix[i][j];
                 matrix[i][j]=matrix[i][col-j-1];
                 matrix[i][col-j-1]=temp;
            }
        }
    }
}
