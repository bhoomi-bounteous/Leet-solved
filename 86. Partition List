class Solution {
    public ListNode partition(ListNode head, int x) {
        ListNode start1=new ListNode(-1);
          ListNode start2=new ListNode(-1);
          ListNode curr=head;
          ListNode curr1=start1;
          ListNode curr2=start2;
          while(curr!=null){
            if(curr.val<x){
                curr1.next=curr;
                curr1=curr1.next;
            }else{
                curr2.next=curr;
                curr2=curr2.next;
            }
            curr=curr.next;
          }
          curr1.next=null;
          curr2.next=null;
          if(curr1==start1) return start2.next;
          if(curr2==start2) return start1.next;
          curr1.next=start2.next;
          return start1.next;
    }
}
