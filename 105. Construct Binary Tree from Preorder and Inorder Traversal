class Solution {
    int preindx=0;
    public TreeNode build(int start,int end,int[] preorder, HashMap<Integer,Integer> map){
     if(start>end) return null;
     TreeNode root= new TreeNode(preorder[preindx++]);
     int indx=map.get(root.val);
     root.left=build(start,indx-1,preorder,map);
     root.right=build(indx+1,end,preorder,map);
     return root;
    }
    public TreeNode buildTree(int[] preorder, int[] inorder) {
        HashMap<Integer,Integer> map=new HashMap<>();
        for(int i=0;i<inorder.length;i++) map.put(inorder[i],i); 
        return build(0,preorder.length-1,preorder,map);
    }
}
