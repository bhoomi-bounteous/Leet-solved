class Solution {
    public Node copyRandomList(Node head) {
        Node curr=head;
        while(curr!=null){
            Node node=new Node(curr.val);
            node.next=curr.next;
            curr.next=node;
            curr=node.next;
        }
        curr=head;
        while(curr!=null){
            if(curr.random!=null)curr.next.random=curr.random.next;
            curr=curr.next.next;
        }
        curr=head;
        Node nhead=new Node(-1);
        Node temp=nhead;
        while(curr!=null){
            temp.next=curr.next;
            curr.next=curr.next.next;
            temp=temp.next;
            curr=curr.next;
        }
        return nhead.next;
    }
}
