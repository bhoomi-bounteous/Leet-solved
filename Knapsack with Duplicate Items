class Solution {
    public int knapSack(int val[], int wt[], int capacity) {
        int n=val.length;
        int[] dp=new int[capacity+1];
        for(int i=n-1;i>=0;i--){
            for(int j=1;j<=capacity;j++){
                int pick=0;
                if(wt[i]<=j) pick=val[i]+dp[j-wt[i]];
                int npick=dp[j];
                dp[j]=Math.max(pick,npick);
            }
        }
        return dp[capacity];
    }
}
