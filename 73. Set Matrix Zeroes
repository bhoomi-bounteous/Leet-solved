class Solution {
    public void setZeroes(int[][] mat) {
        int col=1;
        int rows=mat.length;
        int cols=mat[0].length;
        for(int i=0;i<rows;i++){
            if(mat[i][0]==0) col=0;
            for(int j=1;j<cols;j++){
                if(mat[i][j]==0){
                  mat[0][j]=0;
                    mat[i][0]=0;
                }
            }
        }
        for(int i=rows-1;i>=0;i--){
            for(int j=cols-1;j>=1;j--){
                if(mat[0][j]==0 ||mat[i][0]==0) mat[i][j]=0;
            }
            if(col==0) mat[i][0]=0;
        }
     
    }
}
