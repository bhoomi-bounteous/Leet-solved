class Solution {
    public ListNode addTwoNumbers(ListNode l1, ListNode l2) {
        ListNode curr1=l1;
        ListNode curr2=l2;
        ListNode nhead=new ListNode(-1);
        ListNode curr=nhead;
        int carry=0;
        while(curr1!=null && curr2!=null){
            int sum=curr1.val+curr2.val+carry;
            curr.next=new ListNode(sum%10);
            carry=sum/10;
            curr=curr.next;
            curr1=curr1.next;
            curr2=curr2.next;
        }
        while(curr1!=null){
            int sum=curr1.val+carry;
            curr.next=new ListNode(sum%10);
            carry=sum/10;
            curr=curr.next;
            curr1=curr1.next;
        }
        while(curr2!=null){
             int sum=curr2.val+carry;
            curr.next=new ListNode(sum%10);
            carry=sum/10;
            curr=curr.next;
            curr2=curr2.next;
        }
        if(carry!=0) curr.next=new ListNode(carry);
        return nhead.next;
    }
}
