class Node{
    int data;
    Node next;
    Node(int data){
        this.data=data;
        next=null;
    }
}
class MinStack {
    Node min;
    List<Node> stack;
    public MinStack() {
         min=null;
        stack=new ArrayList<>();
    }
    
    public void push(int val) {
        Node node=new Node(val);
        stack.add(node);
        if(min==null || val<=min.data){
            node.next=min;
            min=node;
        }
    }
    
    public void pop() {
        if(stack.isEmpty()) return;
        Node node=stack.get(stack.size()-1);
        if(node.data==min.data){
            min=node.next;
        }
       if(!stack.isEmpty()) stack.remove(stack.size()-1);
    }
    
    public int top() {
        if(stack.isEmpty()) return -1;
       return stack.get(stack.size()-1).data;
    }
    
    public int getMin() {
        if(stack.isEmpty()) return -1;
        return min.data;
    }
}
