class Solution {
    public int findMinArrowShots(int[][] points) {
        Arrays.sort(points,(a,b)->a[1]-b[1]);
        int count=0;
        int i=0;
        while(i<points.length){
            int prev=points[i][1];
            while(i<points.length && prev>=points[i][0] && prev<=points[i][1]){
                prev=Math.min(points[i][1],prev);
                i++;
            }
            count++;
        }
        return count;
    }
}
