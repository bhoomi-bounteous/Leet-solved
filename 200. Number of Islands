class Solution {
    void dfs(int i,int j,char[][] grid,boolean[][] visit){
        visit[i][j]=true;
        int m=grid.length;
        int n=grid[0].length;
        int[] row={-1,0,1,0};
        int[] col={0,1,0,-1};
        for(int l=0;l<4;l++){
            int r=i+row[l];
            int c=j+col[l];
            if(r>=0 && r<m &&c>=0 && c<n && grid[r][c]=='1' && !visit[r][c]){
                dfs(r,c,grid,visit);
            }
        }
    }
    public int numIslands(char[][] grid) {
        int m=grid.length;
        int n=grid[0].length;
        boolean[][] visit=new boolean[m][n];
        int count=0;
        for(int i=0;i<m;i++){
            for(int j=0;j<n;j++){
                if(grid[i][j]=='1' && !visit[i][j]){
                    dfs(i,j,grid,visit);
                    count++;
                }
            }
        }
        return count;
    }
}
